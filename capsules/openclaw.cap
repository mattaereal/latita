description: OpenClaw AI agent
compatibility:
  profiles: [headless, desktop]
  os_family: [fedora, ubuntu]

provision:
  packages:
    - python3-pip
    - git
  user_commands:
    - |
      pip3 install --user openclaw || true
      echo "OpenClaw installed. Run: openclaw --help"

live:
  user: dev
  commands:
    - pip3 install --user openclaw
    - openclaw --help 2>/dev/null || echo "OpenClaw not available; check pip installation"
