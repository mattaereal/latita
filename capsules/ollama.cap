description: Ollama local LLM server
compatibility:
  profiles: [headless, desktop]
  os_family: [fedora, ubuntu]

provision:
  packages:
    - curl
  user_commands:
    - |
      if [ ! -f /usr/local/bin/ollama ]; then
        curl -fsSL https://ollama.com/install.sh | sh
      fi
      mkdir -p /home/{guest_user}/.ollama
      systemctl --user enable --now ollama || true

live:
  user: dev
  commands:
    - ollama --version || (curl -fsSL https://ollama.com/install.sh | sh)
    - systemctl --user start ollama 2>/dev/null || true
